---
import type { Lang } from '../i18n'
import { t } from '../i18n'
import PrivacyModal from './PrivacyModal.astro'

interface Props { lang: Lang }
const { lang } = Astro.props

const i18n = {
    title:                  t(lang, 'shop.cart.title')                  as string,
    open:                   t(lang, 'shop.cart.open')                   as string,
    empty:                  t(lang, 'shop.cart.empty')                  as string,
    remove:                 t(lang, 'shop.cart.remove')                 as string,
    reserve_btn:            t(lang, 'shop.cart.reserve_btn')            as string,
    back:                   t(lang, 'shop.cart.back')                   as string,
    confirm_title:          t(lang, 'shop.cart.confirm_title')          as string,
    items_singular:         t(lang, 'shop.cart.items_singular')         as string,
    items_plural:           t(lang, 'shop.cart.items_plural')           as string,
    reserve_count_singular: t(lang, 'shop.cart.reserve_count_singular') as string,
    reserve_count_plural:   t(lang, 'shop.cart.reserve_count_plural')   as string,
    name_label:             t(lang, 'shop.modal.name_label')            as string,
    email_label:            t(lang, 'shop.modal.email_label')           as string,
    message_label:          t(lang, 'shop.modal.message_label')         as string,
    message_placeholder:    t(lang, 'shop.modal.message_placeholder')   as string,
    submit:                 t(lang, 'shop.modal.submit')                as string,
    cancel:                 t(lang, 'shop.modal.cancel')                as string,
    sending:                t(lang, 'shop.modal.sending')               as string,
    success:                t(lang, 'shop.modal.success')               as string,
    error:                  t(lang, 'shop.modal.error')                 as string,
    privacy_consent:        t(lang, 'shop.modal.privacy_consent')       as string,
    privacy_link:           t(lang, 'shop.modal.privacy_link')          as string,
    privacy_required:       t(lang, 'shop.modal.privacy_required')      as string,
    email_invalid:          t(lang, 'shop.modal.email_invalid')          as string,
    pickup_notice:          t(lang, 'shop.pickup_notice')               as string,
}
---

<div
    id="cart-backdrop"
    class="fixed inset-0 z-40 bg-bg/70 backdrop-blur-sm hidden"
    aria-hidden="true"
></div>

<div
    id="cart-drawer"
    class="fixed inset-y-0 right-0 z-50 w-full sm:w-96 bg-bg-elevated border-l border-border flex flex-col translate-x-full transition-transform duration-300"
    aria-labelledby="cart-heading"
    role="dialog"
    aria-modal="true"
    data-i18n={JSON.stringify(i18n)}
>
    <div class="flex items-center justify-between px-5 py-4 border-b border-border shrink-0">
        <h2 id="cart-heading" class="font-display font-semibold text-text">{i18n.title}</h2>
        <button
            id="cart-close"
            class="text-text-muted hover:text-text transition-colors duration-200 p-1 rounded"
            aria-label={i18n.cancel}
        >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <div id="cart-items-view" class="flex flex-col flex-1 overflow-hidden">
        <ul id="cart-list" class="flex-1 overflow-y-auto px-4 py-3 space-y-2"></ul>
        <div id="cart-empty" class="flex-1 flex items-center justify-center hidden">
            <p class="text-text-muted text-sm">{i18n.empty}</p>
        </div>
        <div id="cart-footer" class="shrink-0 px-5 py-4 border-t border-border hidden">
            <button
                id="cart-reserve-btn"
                class="w-full py-2.5 bg-accent text-white font-semibold rounded-sm hover:bg-accent-hover text-sm transition-colors duration-200 cursor-pointer"
            >
                {i18n.reserve_btn}
            </button>
        </div>
    </div>

    <div id="cart-form-view" class="flex flex-col flex-1 overflow-hidden hidden">
        <div class="px-5 py-3 border-b border-border shrink-0">
            <button id="cart-back-btn" class="flex items-center gap-2 text-sm text-text-muted hover:text-text transition-colors duration-200 cursor-pointer">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
                {i18n.back}
            </button>
        </div>

        <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4">
            <div id="cart-summary" class="bg-bg rounded-sm border border-border p-3 space-y-1.5 text-sm"></div>

            <div class="flex items-start gap-2.5 text-xs text-text-muted bg-bg-elevated border border-border rounded-sm px-3 py-2.5">
                <svg class="w-4 h-4 shrink-0 mt-0.5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{i18n.pickup_notice}</span>
            </div>

            <div>
                <label for="cart-name" class="block text-sm font-medium text-text-muted mb-1.5">
                    {i18n.name_label} <span class="text-accent">*</span>
                </label>
                <input
                    type="text"
                    id="cart-name"
                    class="w-full bg-bg-card border border-border rounded-sm px-3 py-2 text-text text-sm focus:outline-none focus:ring-1 focus:ring-accent focus:border-accent"
                    required
                    autocomplete="name"
                />
            </div>

            <div>
                <label for="cart-email" class="block text-sm font-medium text-text-muted mb-1.5">
                    {i18n.email_label} <span class="text-accent">*</span>
                </label>
                <input
                    type="email"
                    id="cart-email"
                    class="w-full bg-bg-card border border-border rounded-sm px-3 py-2 text-text text-sm focus:outline-none focus:ring-1 focus:ring-accent focus:border-accent"
                    required
                    autocomplete="email"
                />
            </div>

            <div>
                <label for="cart-message" class="block text-sm font-medium text-text-muted mb-1.5">
                    {i18n.message_label}
                </label>
                <textarea
                    id="cart-message"
                    rows="3"
                    placeholder={i18n.message_placeholder}
                    class="w-full bg-bg-card border border-border rounded-sm px-3 py-2 text-text text-sm focus:outline-none focus:ring-1 focus:ring-accent focus:border-accent resize-none"
                ></textarea>
            </div>

            <label class="flex items-start gap-2.5 cursor-pointer">
                <input
                    type="checkbox"
                    id="cart-privacy"
                    class="mt-0.5 shrink-0 accent-accent cursor-pointer"
                />
                <span class="text-xs text-text-muted leading-relaxed">
                    {i18n.privacy_consent}
                    <button
                        type="button"
                        id="cart-privacy-link"
                        class="underline hover:text-text transition-colors duration-150 cursor-pointer"
                    >{i18n.privacy_link}</button>.
                </span>
            </label>

            <p id="cart-error" class="text-sm text-accent hidden"></p>
        </div>

        <div class="shrink-0 px-5 py-4 border-t border-border">
            <button
                id="cart-submit-btn"
                class="w-full py-2.5 bg-accent text-white font-semibold rounded-sm hover:bg-accent-hover text-sm transition-colors duration-200 cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
            >
                {i18n.submit}
            </button>
        </div>
    </div>

    <div id="cart-success-view" class="flex flex-col flex-1 items-center justify-center gap-4 px-6 text-center hidden">
        <div class="w-14 h-14 rounded-sm bg-accent/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
        </div>
        <p class="text-text leading-relaxed">{i18n.success}</p>
        <button
            id="cart-done-btn"
            class="px-6 py-2.5 bg-accent text-white font-semibold rounded-sm hover:bg-accent-hover text-sm transition-colors duration-200 cursor-pointer"
        >
            {i18n.cancel}
        </button>
    </div>
</div>

<PrivacyModal lang={lang} />

<script>
    import { getCart, saveCart, removeFromCart, totalItems } from '../scripts/cart'
    import type { CartItem } from '../scripts/cart'

    function escHtml(s: string): string {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
    }

    function initCartDrawer() {
        const rawDrawer   = document.getElementById('cart-drawer')
        const rawBackdrop = document.getElementById('cart-backdrop')
        if (!(rawDrawer instanceof HTMLElement) || !(rawBackdrop instanceof HTMLElement)) return
        const drawer: HTMLElement   = rawDrawer
        const backdrop: HTMLElement = rawBackdrop
        const i18nEl = drawer.dataset.i18n ? drawer : null
        if (!i18nEl) return

        const i18n = JSON.parse(i18nEl.dataset.i18n ?? '{}') as Record<string, string>

        const itemsView   = document.getElementById('cart-items-view')
        const formView    = document.getElementById('cart-form-view')
        const successView = document.getElementById('cart-success-view')
        const cartList    = document.getElementById('cart-list')
        const cartEmpty   = document.getElementById('cart-empty')
        const cartFooter  = document.getElementById('cart-footer')
        const cartSummary = document.getElementById('cart-summary')
        const cartError   = document.getElementById('cart-error')
        const nameInput   = document.getElementById('cart-name')    as HTMLInputElement | null
        const emailInput  = document.getElementById('cart-email')   as HTMLInputElement | null
        const msgInput    = document.getElementById('cart-message') as HTMLTextAreaElement | null
        const submitBtn   = document.getElementById('cart-submit-btn') as HTMLButtonElement | null

        function openDrawer() {
            showView('items')
            renderItems()
            drawer.classList.remove('translate-x-full')
            backdrop.classList.remove('hidden')
            document.body.style.overflow = 'hidden'
        }

        function closeDrawer() {
            drawer.classList.add('translate-x-full')
            backdrop.classList.add('hidden')
            document.body.style.overflow = ''
        }

        function showView(view: 'items' | 'form' | 'success') {
            itemsView?.classList.toggle('hidden', view !== 'items')
            formView?.classList.toggle('hidden', view !== 'form')
            successView?.classList.toggle('hidden', view !== 'success')
        }

        function renderItems() {
            const cart  = getCart()
            const count = totalItems(cart)

            const heading = document.getElementById('cart-heading')
            if (heading) {
                const label = count === 1
                    ? `${i18n.title} · 1 ${i18n.items_singular}`
                    : `${i18n.title} · ${count} ${i18n.items_plural}`
                heading.textContent = count > 0 ? label : i18n.title
            }

            if (!cartList) return

            if (cart.length === 0) {
                cartList.classList.add('hidden')
                cartEmpty?.classList.remove('hidden')
                cartFooter?.classList.add('hidden')
                return
            }

            cartList.classList.remove('hidden')
            cartEmpty?.classList.add('hidden')
            cartFooter?.classList.remove('hidden')

            cartList.innerHTML = cart.map((item: CartItem, idx: number) => {
                const details = [item.color, item.size].filter(Boolean).map(escHtml).join(' · ')
                const imgHtml = item.image
                    ? `<img src="${escHtml(item.image)}" alt="" class="w-14 h-14 rounded-sm object-cover shrink-0 bg-bg" onerror="this.style.display='none'" />`
                    : `<div class="w-14 h-14 rounded-sm shrink-0 bg-bg border border-border flex items-center justify-center text-text-subtle">
                           <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3 20.25h18A2.25 2.25 0 0023.25 18V6A2.25 2.25 0 0021 3.75H3A2.25 2.25 0 00.75 6v12A2.25 2.25 0 003 20.25z" /></svg>
                       </div>`
                return `<li>
                    <div class="flex items-center gap-3 bg-bg border border-border rounded-sm p-3">
                        ${imgHtml}
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-text leading-tight truncate">${escHtml(item.productName)}</p>
                            <p class="text-xs text-text-muted mt-0.5">${details ? escHtml(details) + ' · ' : ''}×${item.quantity}</p>
                        </div>
                        <button
                            class="text-text-subtle hover:text-accent transition-colors duration-150 shrink-0 p-1 cursor-pointer"
                            data-remove="${idx}"
                            aria-label="${escHtml(i18n.remove)}"
                        >
                            <svg class="w-4 h-4 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </li>`
            }).join('')

            const reserveBtn = document.getElementById('cart-reserve-btn')
            if (reserveBtn) {
                const tpl = count === 1 ? i18n.reserve_count_singular : i18n.reserve_count_plural
                reserveBtn.textContent = tpl.replace('{n}', String(count))
            }

            cartList.querySelectorAll<HTMLElement>('[data-remove]').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const idx = parseInt(btn.dataset.remove ?? '0', 10)
                    removeFromCart(idx)
                    renderItems()
                })
            })
        }

        function showForm() {
            const cart = getCart()
            if (!cartSummary) return

            cartSummary.innerHTML = cart.map((item: CartItem) => {
                const details = [item.color, item.size].filter(Boolean).map(escHtml).join(' · ')
                return `
                <div class="flex justify-between text-xs">
                    <span class="text-text">${escHtml(item.productName)}${details ? ` <span class="text-text-muted">(${details})</span>` : ''}</span>
                    <span class="text-text-muted shrink-0 ml-2">×${item.quantity}</span>
                </div>`
            }).join('')

            if (nameInput) nameInput.value = ''
            if (emailInput) emailInput.value = ''
            if (msgInput) msgInput.value = ''
            const privacyCheckReset = document.getElementById('cart-privacy') as HTMLInputElement | null
            if (privacyCheckReset) privacyCheckReset.checked = false
            if (cartError) cartError.classList.add('hidden')
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = i18n.submit }

            showView('form')
            nameInput?.focus()
        }

        async function submitReservation() {
            if (!submitBtn) return
            const cart  = getCart()
            const name  = nameInput?.value.trim()  ?? ''
            const email = emailInput?.value.trim() ?? ''
            const msg   = msgInput?.value.trim()   ?? ''
            if (!name || !email || cart.length === 0) return
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                if (cartError) { cartError.textContent = i18n.email_invalid; cartError.classList.remove('hidden') }
                return
            }

            const privacyCheck = document.getElementById('cart-privacy') as HTMLInputElement | null
            if (!privacyCheck?.checked) {
                if (cartError) { cartError.textContent = i18n.privacy_required; cartError.classList.remove('hidden') }
                return
            }

            submitBtn.disabled = true
            submitBtn.textContent = i18n.sending

            try {
                const res = await fetch('/api/reserva', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        items: cart.map((item: CartItem) => ({
                            product_name: item.productName,
                            size:         item.size,
                            color:        item.color,
                            quantity:     item.quantity,
                        })),
                        customer_name:  name,
                        customer_email: email,
                        message:        msg,
                    }),
                })
                const json = await res.json() as { ok: boolean }
                if (!json.ok) throw new Error('not ok')
                saveCart([])
                showView('success')
            } catch {
                if (cartError) { cartError.textContent = i18n.error; cartError.classList.remove('hidden') }
                submitBtn.disabled = false
                submitBtn.textContent = i18n.submit
            }
        }

        document.getElementById('cart-close')?.addEventListener('click', closeDrawer)
        document.getElementById('cart-done-btn')?.addEventListener('click', closeDrawer)
        backdrop.addEventListener('click', closeDrawer)
        document.getElementById('cart-reserve-btn')?.addEventListener('click', showForm)
        document.getElementById('cart-back-btn')?.addEventListener('click', () => { showView('items'); renderItems() })
        document.getElementById('cart-submit-btn')?.addEventListener('click', submitReservation)

        document.getElementById('cart-privacy-link')?.addEventListener('click', () => {
            document.dispatchEvent(new Event('open-privacy-modal'))
        })

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const privacyModal = document.getElementById('privacy-modal') as HTMLElement | null
                if (privacyModal && privacyModal.style.display !== 'none') return
                if (!drawer.classList.contains('translate-x-full')) closeDrawer()
            }
        })

        document.addEventListener('open-cart', () => openDrawer())
        document.addEventListener('cart-updated', () => {
            if (!drawer.classList.contains('translate-x-full')) renderItems()
        })
    }

    initCartDrawer()
</script>
