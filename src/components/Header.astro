---
import type { Lang } from '../i18n'
import { t, LANGUAGES } from '../i18n'

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const pathname = Astro.url.pathname
const currentSlug = pathname.split('/').filter(Boolean).slice(1).join('/')

function isActive(slug: string): boolean {
    if (slug === '') return currentSlug === ''
    return currentSlug === slug || currentSlug.startsWith(slug + '/')
}

function langSwitchUrl(targetLang: string): string {
    return currentSlug ? `/${targetLang}/${currentSlug}` : `/${targetLang}/`
}

const presentationChildren = [
    { key: 'dragon', slug: 'el-drac' },
    { key: 'small_dragon', slug: 'el-drac-petit' },
    { key: 'friends', slug: 'els-amics-del-drac' },
]

const historyChildren = [
    { key: 'history_origins', slug: 'historia/origens' },
    { key: 'history_s17', slug: 'historia/segle-xvii' },
    { key: 'history_s18', slug: 'historia/segle-xviii' },
    { key: 'history_s19', slug: 'historia/segle-xix' },
    { key: 'history_s20', slug: 'historia/segle-xx' },
    { key: 'history_s21', slug: 'historia/segle-xxi' },
]

const isPresentationActive = presentationChildren.some(({ slug }) => isActive(slug))

const navLinkClass = (slug: string) =>
    `px-3 py-2 text-sm rounded-md transition-colors duration-200 ${
        isActive(slug) ? 'text-text' : 'text-text-muted hover:text-text'
    }`
---

<header id="site-header" class="fixed top-0 inset-x-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            <a href={`/${lang}/`} class="font-display font-black text-base lg:text-lg leading-none shrink-0">
                <span class="text-accent">Drac</span><span class="text-text"> de Vilafranca</span>
            </a>

            <nav class="hidden lg:flex items-center gap-0.5" aria-label={t(lang, 'nav.main_nav')}>
                <a href={`/${lang}/`} class={navLinkClass('')}>
                    {t(lang, 'nav.home')}
                </a>

                <div class="relative group">
                    <span
                        class={`flex items-center gap-1 px-3 py-2 text-sm rounded-md transition-colors duration-200 select-none cursor-default ${isPresentationActive ? 'text-text' : 'text-text-muted group-hover:text-text'}`}
                        aria-hidden="true"
                    >
                        {t(lang, 'nav.presentation')}
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                            fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                            aria-hidden="true"
                        >
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                    <!-- Invisible bridge: fills the gap between trigger and dropdown so hover isn't lost while moving the cursor -->
                    <div class="absolute top-full inset-x-0 h-2 z-50" aria-hidden="true"></div>
                    <ul
                        class="absolute top-full left-0 mt-1 w-52 bg-bg-elevated border border-border rounded-lg shadow-xl
                               opacity-0 invisible pointer-events-none
                               group-hover:opacity-100 group-hover:visible group-hover:pointer-events-auto
                               transition-all duration-200 z-50 py-1"
                        role="menu"
                    >
                        {presentationChildren.map(({ key, slug }) => (
                            <li role="none">
                                <a
                                    href={`/${lang}/${slug}`}
                                    class={`block px-4 py-2 text-sm transition-colors duration-150 ${
                                        isActive(slug) ? 'text-gold bg-surface' : 'text-text-muted hover:text-text hover:bg-surface'
                                    }`}
                                    role="menuitem"
                                >
                                    {t(lang, `nav.${key}`)}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>

                <div class="relative group">
                    <span
                        class={`flex items-center gap-1 px-3 py-2 text-sm rounded-md transition-colors duration-200 select-none cursor-default ${isActive('historia') ? 'text-text' : 'text-text-muted group-hover:text-text'}`}
                        aria-hidden="true"
                    >
                        {t(lang, 'nav.history')}
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                            fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                            aria-hidden="true"
                        >
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                    <!-- Invisible bridge: fills the gap between trigger and dropdown so hover isn't lost while moving the cursor -->
                    <div class="absolute top-full inset-x-0 h-2 z-50" aria-hidden="true"></div>
                    <ul
                        class="absolute top-full left-0 mt-1 w-52 bg-bg-elevated border border-border rounded-lg shadow-xl
                               opacity-0 invisible pointer-events-none
                               group-hover:opacity-100 group-hover:visible group-hover:pointer-events-auto
                               transition-all duration-200 z-50 py-1"
                        role="menu"
                    >
                        {historyChildren.map(({ key, slug }) => (
                            <li role="none">
                                <a
                                    href={`/${lang}/${slug}`}
                                    class={`block px-4 py-2 text-sm transition-colors duration-150 ${
                                        isActive(slug) ? 'text-gold bg-surface' : 'text-text-muted hover:text-text hover:bg-surface'
                                    }`}
                                    role="menuitem"
                                >
                                    {t(lang, `nav.${key}`)}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>

                <a href={`/${lang}/esdeveniments`} class={navLinkClass('esdeveniments')}>
                    {t(lang, 'nav.events')}
                </a>
                <a href={`/${lang}/botiga`} class={navLinkClass('botiga')}>
                    {t(lang, 'nav.shop')}
                </a>
                <a href={`/${lang}/contacte`} class={navLinkClass('contacte')}>
                    {t(lang, 'nav.contact')}
                </a>
            </nav>

            <div class="flex items-center gap-2 shrink-0">
                <button
                    id="cart-toggle"
                    class="relative p-1.5 rounded-md text-text-muted hover:text-text transition-colors duration-200"
                    aria-label={t(lang, 'shop.cart.open')}
                >
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 11H4L5 9z" />
                    </svg>
                    <span
                        id="cart-badge"
                        class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-accent text-white text-[10px] font-bold rounded-full flex items-center justify-center hidden"
                        aria-hidden="true"
                    ></span>
                </button>

                <div class="flex gap-1" role="navigation" aria-label={t(lang, 'nav.language')}>
                    {LANGUAGES.map((l) => (
                        <a
                            href={langSwitchUrl(l)}
                            class={`px-2 py-0.5 text-xs font-bold rounded transition-colors duration-200 ${
                                l === lang
                                    ? 'bg-accent text-white'
                                    : 'text-text-subtle border border-border hover:text-text hover:border-border-light'
                            }`}
                            aria-current={l === lang ? 'page' : undefined}
                            lang={l}
                            hreflang={l}
                        >
                            {l.toUpperCase()}
                        </a>
                    ))}
                </div>

                <button
                    id="menu-toggle"
                    class="lg:hidden p-1.5 rounded-md text-text-muted hover:text-text transition-colors duration-200"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                    aria-label={t(lang, 'nav.open_menu')}
                >
                    <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

        </div>
    </div>
</header>

<div
    id="mobile-menu"
    class="mobile-menu fixed inset-0 z-30 lg:hidden"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label={t(lang, 'nav.open_menu')}
>
    <div class="flex flex-col h-full px-4 pt-20 pb-8 overflow-y-auto">
        <nav aria-label={t(lang, 'nav.mobile_nav')}>
            <ul class="flex flex-col gap-0.5">
                <li>
                    <a href={`/${lang}/`} class="block px-4 py-3 text-lg font-medium text-text-muted hover:text-text hover:bg-surface rounded-lg transition-colors duration-200">
                        {t(lang, 'nav.home')}
                    </a>
                </li>
                <li>
                    <span class="block px-4 py-3 text-lg font-medium text-text-subtle">
                        {t(lang, 'nav.presentation')}
                    </span>
                    <ul class="ml-6 border-l border-border pl-3 mb-1">
                        {presentationChildren.map(({ key, slug }) => (
                            <li>
                                <a href={`/${lang}/${slug}`} class="block px-3 py-2 text-sm text-text-muted hover:text-text transition-colors duration-200">
                                    {t(lang, `nav.${key}`)}
                                </a>
                            </li>
                        ))}
                    </ul>
                </li>
                <li>
                    <span class="block px-4 py-3 text-lg font-medium text-text-subtle">
                        {t(lang, 'nav.history')}
                    </span>
                    <ul class="ml-6 border-l border-border pl-3 mb-1">
                        {historyChildren.map(({ key, slug }) => (
                            <li>
                                <a href={`/${lang}/${slug}`} class="block px-3 py-2 text-sm text-text-subtle hover:text-text-muted transition-colors duration-200">
                                    {t(lang, `nav.${key}`)}
                                </a>
                            </li>
                        ))}
                    </ul>
                </li>
                <li>
                    <a href={`/${lang}/esdeveniments`} class="block px-4 py-3 text-lg font-medium text-text-muted hover:text-text hover:bg-surface rounded-lg transition-colors duration-200">
                        {t(lang, 'nav.events')}
                    </a>
                </li>
                <li>
                    <a href={`/${lang}/botiga`} class="block px-4 py-3 text-lg font-medium text-text-muted hover:text-text hover:bg-surface rounded-lg transition-colors duration-200">
                        {t(lang, 'nav.shop')}
                    </a>
                </li>
                <li>
                    <a href={`/${lang}/contacte`} class="block px-4 py-3 text-lg font-medium text-text-muted hover:text-text hover:bg-surface rounded-lg transition-colors duration-200">
                        {t(lang, 'nav.contact')}
                    </a>
                </li>
            </ul>
        </nav>

        <div class="mt-8 pt-6 border-t border-border">
            <p class="text-xs text-text-subtle uppercase tracking-widest mb-3">{t(lang, 'nav.language')}</p>
            <div class="flex gap-2">
                {LANGUAGES.map((l) => (
                    <a
                        href={langSwitchUrl(l)}
                        class={`px-4 py-2 text-sm font-bold rounded-md transition-colors duration-200 ${
                            l === lang
                                ? 'bg-accent text-white'
                                : 'text-text-muted border border-border hover:text-text hover:border-border-light'
                        }`}
                        lang={l}
                        hreflang={l}
                    >
                        {l.toUpperCase()} — {t(lang, `common.lang_${l}`)}
                    </a>
                ))}
            </div>
        </div>
    </div>
</div>

<script>
    const header = document.getElementById('site-header')
    const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement | null
    const mobileMenu = document.getElementById('mobile-menu')
    const iconOpen = document.getElementById('icon-open')
    const iconClose = document.getElementById('icon-close')

    function updateHeader() {
        header?.classList.toggle('scrolled', window.scrollY > 20)
    }
    window.addEventListener('scroll', updateHeader, { passive: true })
    updateHeader()

    let isOpen = false

    function setMenuOpen(open: boolean) {
        isOpen = open
        mobileMenu?.classList.toggle('is-open', open)
        menuToggle?.setAttribute('aria-expanded', String(open))
        mobileMenu?.setAttribute('aria-hidden', String(!open))
        document.body.style.overflow = open ? 'hidden' : ''
        iconOpen?.classList.toggle('hidden', open)
        iconClose?.classList.toggle('hidden', !open)
    }

    menuToggle?.addEventListener('click', () => setMenuOpen(!isOpen))

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) setMenuOpen(false)
    })

    window.addEventListener('resize', () => {
        if (window.innerWidth >= 1024 && isOpen) setMenuOpen(false)
    })
</script>

<script>
    import { getCart, totalItems } from '../scripts/cart'

    function updateBadge() {
        const badge = document.getElementById('cart-badge')
        if (!badge) return
        const count = totalItems(getCart())
        badge.textContent = count > 9 ? '9+' : String(count)
        badge.classList.toggle('hidden', count === 0)
    }

    document.getElementById('cart-toggle')?.addEventListener('click', () => {
        document.dispatchEvent(new Event('open-cart'))
    })

    document.addEventListener('cart-updated', updateBadge)
    updateBadge()
</script>
