---
interface Props {
    title: string
    supertitle?: string
    subtitle?: string
}

const { title, supertitle, subtitle } = Astro.props
---

<div class="mb-10">
    <div class="h-0.5 w-16 bg-linear-to-r from-accent to-gold mb-6"></div>
    {supertitle && (
        <p class="text-xs font-bold uppercase tracking-widest text-text-subtle mb-3">{supertitle}</p>
    )}
    <h1 class:list={['text-4xl md:text-5xl font-display font-bold text-text', subtitle && 'mb-4']}>{title}</h1>
    {subtitle && (
        <p class="text-text-muted leading-relaxed">{subtitle}</p>
    )}
</div>
