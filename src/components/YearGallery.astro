---
import type { Lang } from '../i18n'
import { t } from '../i18n'

interface Props {
    lang: Lang
}

const { lang } = Astro.props

const i18n = {
    loading: t(lang, 'gallery.loading'),
    error: t(lang, 'gallery.error'),
    empty: t(lang, 'gallery.empty'),
    photo_alt: t(lang, 'gallery.photo_alt'),
    prev: t(lang, 'gallery.prev'),
    next: t(lang, 'gallery.next'),
}
---

<div class="year-gallery" data-i18n={JSON.stringify(i18n)}>
    <p class="text-text-muted text-sm">{t(lang, 'gallery.loading')}</p>
</div>

<script>
    async function fetchGalleryList(): Promise<string[]> {
        const r = await fetch('/gallery/list.json')
        if (!r.ok) throw new Error('fetch failed')
        const data = await r.json()
        return Array.isArray(data.files) ? data.files : []
    }

    function escapeHtml(str: string) {
        return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
    }

    document.querySelectorAll<HTMLElement>('.year-gallery').forEach(async (el) => {
        const i18n = JSON.parse(el.dataset.i18n || '{}')

        let files: string[] = []
        try {
            files = await fetchGalleryList()
        } catch {
            el.innerHTML = `<p class="text-accent text-sm">${i18n.error}</p>`
            return
        }

        if (files.length === 0) {
            el.innerHTML = `<p class="text-text-muted text-sm py-4">${i18n.empty}</p>`
            return
        }

        // Newest first
        files.sort((a, b) => b.localeCompare(a))

        let idx = 0

        // Render structure once
        const firstFile = files[0]
        const firstYear = escapeHtml(firstFile.replace(/\.(jpg|jpeg|png|webp|gif)$/i, ''))
        el.innerHTML = `
            <div class="flex items-center justify-center gap-6 mb-6">
                <button
                    id="gallery-prev"
                    class="w-9 h-9 flex items-center justify-center rounded-sm border border-border text-text-muted hover:text-text hover:border-border-light transition-colors duration-200"
                    aria-label="${escapeHtml(i18n.prev)}"
                >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <span id="gallery-year" class="font-display font-bold text-2xl text-text tabular-nums w-16 text-center">${firstYear}</span>
                <button
                    id="gallery-next"
                    class="w-9 h-9 flex items-center justify-center rounded-sm border border-border text-text-muted hover:text-text hover:border-border-light transition-colors duration-200"
                    aria-label="${escapeHtml(i18n.next)}"
                >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </div>
            <figure>
                <div class="overflow-hidden rounded-sm border border-border bg-bg-card h-80 sm:h-96 md:h-[28rem]">
                    <img
                        id="gallery-img"
                        src="/gallery/${escapeHtml(firstFile)}"
                        alt="${i18n.photo_alt} ${firstYear}"
                        class="w-full h-full object-cover"
                        loading="lazy"
                    />
                </div>
                <figcaption id="gallery-caption" class="text-text-subtle text-sm italic text-center mt-3">
                    ${i18n.photo_alt} ${firstYear}
                </figcaption>
            </figure>
        `

        const yearEl = el.querySelector('#gallery-year')
        const imgEl = el.querySelector<HTMLImageElement>('#gallery-img')
        const captionEl = el.querySelector('#gallery-caption')

        function update() {
            const file = files[idx]
            const year = file.replace(/\.(jpg|jpeg|png|webp|gif)$/i, '')
            if (yearEl) yearEl.textContent = year
            if (imgEl) { imgEl.src = `/gallery/${file}`; imgEl.alt = `${i18n.photo_alt} ${year}` }
            if (captionEl) captionEl.textContent = `${i18n.photo_alt} ${year}`
        }

        el.querySelector('#gallery-prev')?.addEventListener('click', () => {
            idx = (idx - 1 + files.length) % files.length
            update()
        })
        el.querySelector('#gallery-next')?.addEventListener('click', () => {
            idx = (idx + 1) % files.length
            update()
        })
    })
</script>
