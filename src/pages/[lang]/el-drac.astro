---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHeader from '../../components/PageHeader.astro'
import ContentImage from '../../components/ContentImage.astro'
import { getStaticLangPaths, t } from '../../i18n'
import type { Lang } from '../../i18n'

export function getStaticPaths() {
    return getStaticLangPaths()
}

const { lang } = Astro.params as { lang: Lang }
const paragraphs = t(lang, 'dragon.paragraphs') as string[]
---

<BaseLayout lang={lang} title={t(lang, 'dragon.title')}>
    <main id="main-content" class="pt-24 min-h-screen">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

            <PageHeader title={t(lang, 'dragon.title') as string} />

            <div class="mb-10 overflow-hidden rounded-lg border border-border bg-bg-card">
                <img
                    src="/images/drac-panoramic.jpg"
                    alt={t(lang, 'dragon.title') as string}
                    class="w-full h-auto object-cover"
                    loading="eager"
                    width="1200"
                    height="400"
                />
            </div>

            <div class="space-y-6">
                {paragraphs.map((p) => (
                    <p class="text-text-muted leading-relaxed">{p}</p>
                ))}
            </div>

            <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 gap-6">
                <ContentImage
                    src="/images/drac-interior-head.jpg"
                    alt={t(lang, 'dragon.interior.head_caption') as string}
                    caption={t(lang, 'dragon.interior.head_caption') as string}
                    width={600}
                    height={450}
                />
                <ContentImage
                    src="/images/drac-interior-tail.jpg"
                    alt={t(lang, 'dragon.interior.tail_caption') as string}
                    caption={t(lang, 'dragon.interior.tail_caption') as string}
                    width={600}
                    height={450}
                />
            </div>

        </div>
    </main>
</BaseLayout>
