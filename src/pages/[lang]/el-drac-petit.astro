---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHeader from '../../components/PageHeader.astro'
import { getStaticLangPaths, t } from '../../i18n'
import type { Lang } from '../../i18n'

export function getStaticPaths() {
    return getStaticLangPaths()
}

const { lang } = Astro.params as { lang: Lang }
const paragraphs = t(lang, 'small_dragon.paragraphs') as string[]
---

<BaseLayout lang={lang} title={t(lang, 'small_dragon.title')}>
    <main id="main-content" class="pt-24 min-h-screen">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

            <PageHeader title={t(lang, 'small_dragon.title') as string} />

            <div class="mb-10 overflow-hidden rounded-lg border border-border bg-bg-card">
                <img
                    src="/images/drac-petit.jpg"
                    alt={t(lang, 'small_dragon.title') as string}
                    class="w-full h-auto object-cover"
                    loading="eager"
                    width="1024"
                    height="682"
                />
            </div>

            <div class="space-y-6">
                {paragraphs.slice(0, 2).map((p) => (
                    <p class="text-text-muted leading-relaxed">{p}</p>
                ))}
            </div>

            <div class="my-10 overflow-hidden rounded-lg border border-border bg-bg-card">
                <img
                    src="/images/drac-petit.jpg"
                    alt={t(lang, 'small_dragon.title') as string}
                    class="w-full h-auto object-cover"
                    loading="lazy"
                    width="1024"
                    height="682"
                />
            </div>

            <div class="space-y-6">
                {paragraphs.slice(2).map((p) => (
                    <p class="text-text-muted leading-relaxed">{p}</p>
                ))}
            </div>

        </div>
    </main>
</BaseLayout>
