---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Timeline from '../../../components/Timeline.astro'
import PageHeader from '../../../components/PageHeader.astro'
import ContentImage from '../../../components/ContentImage.astro'
import { getStaticLangPaths, t } from '../../../i18n'
import type { Lang } from '../../../i18n'

export function getStaticPaths() {
    return getStaticLangPaths()
}

const { lang } = Astro.params as { lang: Lang }
const paragraphs = t(lang, 'history.origins.paragraphs') as string[]
---

<BaseLayout lang={lang} title={t(lang, 'history.origins.title')}>
    <main id="main-content" class="pt-24 min-h-screen">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

            <PageHeader
                supertitle={t(lang, 'history.title') as string}
                title={t(lang, 'history.origins.title') as string}
            />

            <Timeline lang={lang} current="origens" />

            <div class="space-y-6 mb-10">
                {paragraphs.slice(0, 1).map((p) => (
                    <p class="text-text-muted leading-relaxed">{p}</p>
                ))}
            </div>

            <div class="mb-10">
                <ContentImage
                    src="/images/drac-medieval.gif"
                    alt={t(lang, 'history.origins.title') as string}
                    width={800}
                    height={520}
                />
            </div>

            <div class="space-y-6 mb-10">
                {paragraphs.slice(1, 3).map((p) => (
                    <p class="text-text-muted leading-relaxed">{p}</p>
                ))}
            </div>

            <div class="grid grid-cols-2 gap-4 mb-10">
                <ContentImage
                    src="/images/auca-drac.gif"
                    alt={t(lang, 'history.origins.auca_drac_caption') as string}
                    caption={t(lang, 'history.origins.auca_drac_caption') as string}
                    width={400}
                    height={560}
                    smallCaption
                />
                <ContentImage
                    src="/images/auca-aliga.gif"
                    alt={t(lang, 'history.origins.auca_aliga_caption') as string}
                    caption={t(lang, 'history.origins.auca_aliga_caption') as string}
                    width={400}
                    height={560}
                    smallCaption
                />
            </div>

            <div class="space-y-6">
                {paragraphs.slice(3).map((p) => (
                    <p class="text-text-muted leading-relaxed">{p}</p>
                ))}
            </div>

            <div class="mt-14">
                <Timeline lang={lang} current="origens" compact />
            </div>

        </div>
    </main>
</BaseLayout>
