---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHeader from '../../components/PageHeader.astro'
import ContentImage from '../../components/ContentImage.astro'
import YearGallery from '../../components/YearGallery.astro'
import { getStaticLangPaths, t } from '../../i18n'
import type { Lang } from '../../i18n'

export function getStaticPaths() {
    return getStaticLangPaths()
}

const { lang } = Astro.params as { lang: Lang }
const historyParagraphs = t(lang, 'friends.history_paragraphs') as string[]
---

<BaseLayout lang={lang} title={t(lang, 'friends.title')}>
    <main id="main-content" class="pt-24 min-h-screen">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

            <PageHeader title={t(lang, 'friends.title') as string} />

            <section class="mb-16" aria-labelledby="history-title">
                <h2
                    id="history-title"
                    class="text-xs font-bold uppercase tracking-widest text-text-subtle mb-6"
                >
                    {t(lang, 'friends.history_title')}
                </h2>

                <div class="space-y-5">
                    {historyParagraphs.slice(0, 4).map((p) => (
                        <p class="text-text-muted leading-relaxed">{p}</p>
                    ))}
                </div>

                <figure class="my-8">
                    <ContentImage
                        src="/images/expo-bestiari.jpg"
                        alt={t(lang, 'friends.expo_caption') as string}
                        caption={t(lang, 'friends.expo_caption') as string}
                        width={400}
                        height={560}
                        imageClass="max-w-xs mx-auto"
                    />
                </figure>

                <div class="space-y-5">
                    {historyParagraphs.slice(4).map((p) => (
                        <p class="text-text-muted leading-relaxed">{p}</p>
                    ))}
                </div>
            </section>

            <div class="h-px bg-border mb-16"></div>

            <section class="mb-16" aria-labelledby="gaudeamus-title">
                <h2
                    id="gaudeamus-title"
                    class="text-xs font-bold uppercase tracking-widest text-text-subtle mb-6"
                >
                    {t(lang, 'friends.gaudeamus_title')}
                </h2>
                <p class="text-text-muted leading-relaxed">
                    {t(lang, 'friends.gaudeamus_text')}
                </p>
            </section>

            <div class="h-px bg-border mb-16"></div>

            <section class="mb-16" aria-labelledby="gallery-title">
                <h2
                    id="gallery-title"
                    class="text-xs font-bold uppercase tracking-widest text-text-subtle mb-6"
                >
                    {t(lang, 'friends.gallery_title')}
                </h2>
                <YearGallery lang={lang} />
            </section>

        </div>
    </main>
</BaseLayout>
