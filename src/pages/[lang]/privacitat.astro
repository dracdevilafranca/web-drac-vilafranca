---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHeader from '../../components/PageHeader.astro'
import { getStaticLangPaths, t } from '../../i18n'
import type { Lang } from '../../i18n'
import { privacyContent } from '../../data/privacy'

export function getStaticPaths() {
    return getStaticLangPaths()
}

const { lang } = Astro.params as { lang: Lang }
const { sections } = privacyContent[lang]
---

<BaseLayout
    lang={lang}
    title={t(lang, 'privacy.title') as string}
    description={t(lang, 'privacy.subtitle') as string}
>
    <main id="main-content" class="pt-24 min-h-screen">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

            <PageHeader
                title={t(lang, 'privacy.title') as string}
                subtitle={t(lang, 'privacy.subtitle') as string}
            />

            <div class="space-y-8">
                {sections.map((section) => (
                    <section>
                        <h2 class="text-lg font-semibold text-text mb-2">{section.heading}</h2>
                        <p class="text-text leading-relaxed">{section.body}</p>
                    </section>
                ))}
            </div>

        </div>
    </main>
</BaseLayout>
