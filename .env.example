# Variables d'entorn necessàries per al projecte
# Copia aquest fitxer a .env per a desenvolupament local (mai pujar .env al git)

# Clau API de Resend per enviar els correus de reserva
# 1. Crea un compte a https://resend.com (gratu per fins a 3.000 correus/mes)
# 2. Verifica el domini dracdevilafranca.com (Settings → Domains → Add Domain)
# 3. Crea una API Key (API Keys → Create API Key)
# 4. Afegeix-la a Cloudflare Pages: Settings → Environment variables → Add variable (Secret)
#    Nom: RESEND_API_KEY  |  Tipus: Secret
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
